# Okta API (scanning target tenant)
OKTA_API_TOKEN=
OKTA_ORG=
OKTA_ORG_TYPE=okta

# Okta Auth (ASPM app login)
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_ISSUER=

# Encryption (REQUIRED - generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Database
# Database (use 'db' for Docker, 'localhost' for local dev)
DATABASE_URL=postgresql+asyncpg://aspm:aspm@db:5432/aspm

# Redis (use 'redis' for Docker, 'localhost' for local dev)
REDIS_URL=redis://redis:6379/0

# App (SECRET_KEY is REQUIRED - generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=
LOG_LEVEL=INFO
MAX_WORKERS=5
API_DELAY=0
REPORTS_DIR=/data/reports
RETENTION_DAYS=180
ALLOWED_ORIGINS=http://localhost:5173
# Set to false for local dev without HTTPS
COOKIE_SECURE=true
