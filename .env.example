# =============================================================================
# Okta API (scanning target tenant)
# =============================================================================
# Your Okta SSWS API token — create one at:
# https://<your-org>-admin.okta.com/admin/access/api/tokens
OKTA_API_TOKEN=00aBcDeFgHiJkLmNoPqRsTuVwXyZ

# Your Okta org subdomain (e.g. "dev-12345678", "mycompany")
OKTA_ORG=dev-12345678

# "okta" for production orgs, "oktapreview" for preview/dev orgs
OKTA_ORG_TYPE=okta

# =============================================================================
# Okta Auth (OIDC login for the ASPM dashboard)
# =============================================================================
# Create a "Web" application in Okta Admin > Applications > Create App Integration
# Set Sign-in redirect URI to: http://localhost:8000/api/v1/auth/callback
OKTA_CLIENT_ID=0oaXXXXXXXXXXXXXXXX
OKTA_CLIENT_SECRET=your-client-secret-here

# Your Okta org URL (no trailing slash)
# For most orgs: https://<your-org>.okta.com
# For preview orgs: https://<your-org>.oktapreview.com
OKTA_ISSUER=https://dev-12345678.okta.com

# =============================================================================
# Encryption
# =============================================================================
# Fernet key for encrypting API tokens at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# =============================================================================
# Database (use 'db' for Docker, 'localhost' for local dev)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://aspm:aspm@db:5432/aspm

# =============================================================================
# Redis (use 'redis' for Docker, 'localhost' for local dev)
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# App
# =============================================================================
# Session signing key
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Max concurrent Okta API calls per scan (respect rate limits)
MAX_WORKERS=5

# Optional delay (seconds) between users in batch scans
API_DELAY=0

# Directory for generated reports (inside Docker container)
REPORTS_DIR=/data/reports

# Auto-delete assessment data older than this many days
RETENTION_DAYS=180

# Frontend URL for CORS (comma-separated for multiple origins)
ALLOWED_ORIGINS=http://localhost:5173

# Set to false for local dev without HTTPS
COOKIE_SECURE=false
